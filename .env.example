# ⚠️ IMPORTANTE: Copia este archivo a .env y configura tus credenciales reales
# Supabase Configuration
# Get your credentials from: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Analytics (optional)
# Get your Measurement ID from: https://analytics.google.com/
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# GOOGLE GMAIL API (Recomendado para envío de emails)
# ============================================
# ¡Esta es la forma profesional de enviar emails!
#
# PASO 1: Crear proyecto en Google Cloud Console
# - Ve a: https://console.cloud.google.com/
# - Crea un nuevo proyecto
#
# PASO 2: Habilitar Gmail API
# - En "APIs & Services" > "Library"
# - Busca "Gmail API" y habilítala
#
# PASO 3: Crear credenciales OAuth 2.0
# - Ve a "APIs & Services" > "Credentials"
# - Click en "Create Credentials" > "OAuth client ID"
# - Tipo: "Web application"
# - Orígenes JavaScript autorizados (agrega todos):
#   * http://localhost:3000
#   * http://localhost:3001
#   * http://localhost:3002
#   * https://tu-dominio.vercel.app (cuando despliegues)
# - URIs de redirección autorizadas:
#   * Agrega la URL de tu app
#
# PASO 4: Copiar credenciales
# - Desde el dashboard de Google Cloud Console
# - Copia tu Client ID y API Key (opcional)
#
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
VITE_GOOGLE_API_KEY=your-google-api-key-here

# EmailJS Configuration (alternativa, no recomendado)
# Si prefieres EmailJS en lugar de Gmail API, configura esto:
VITE_EMAILJS_PUBLIC_KEY=your-public-key-here
VITE_EMAILJS_SERVICE_ID=your-service-id-here
VITE_EMAILJS_TEMPLATE_ID=your-template-id-here
